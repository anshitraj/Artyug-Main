# ─────────────────────────────────────────────────────────────────────────────
# ARTYUG — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
# OAuth redirect: must match an entry in Supabase Dashboard → Authentication → URL Configuration
# → Redirect URLs (e.g. https://app.artyug.art or https://app.artyug.art/). If unset, web uses the
# browser origin only — set this when the app is served behind a proxy or a fixed public URL.
# OAUTH_REDIRECT_URL=https://app.artyug.art

# ─── App Mode ────────────────────────────────────────────────────────────────
# demo  → uses mocked data, no payments, no live blockchain
# live  → real Supabase, real checkout (Razorpay / Dodo / Stripe), Solana
# Must match what you want at first launch; the in-app Demo/Live toggle is saved
# in device storage and overrides this after the first switch.
ARTYUG_APP_MODE=demo

# ─── Blockchain / Solana ─────────────────────────────────────────────────────
# devnet  → free test network (safe for development)
# mainnet → real money (requires funded wallet)
ARTYUG_CHAIN_MODE=devnet
# Public devnet (OK on mobile/desktop; Flutter web often needs a provider URL with CORS):
# SOLANA_RPC_URL=https://api.devnet.solana.com
# Helius (replace YOUR_KEY): https://devnet.helius-rpc.com/?api-key=YOUR_KEY
# Alchemy Solana devnet: https://solana-devnet.g.alchemy.com/v2/YOUR_KEY
SOLANA_RPC_URL=https://api.devnet.solana.com

# Fee payer secret used to SIGN the memo transaction (must hold SOL on that network).
# Phantom: Settings → Security → Export private key → paste here (base58, usually 64-byte keypair).
# Solana CLI: bytes from ~/.config/solana/id.json as JSON array are NOT base58 — use `solana-keygen pubkey` / keytool or Phantom export.
# SOLANA_WALLET_ADDRESS alone does NOT sign — leave blank or use only for your own notes.
SOLANA_WALLET_ADDRESS=
SOLANA_PRIVATE_KEY=

# ─── Feature Flags ───────────────────────────────────────────────────────────
ENABLE_NFC=true
# Solana memo attestation: default ON. Set to false / 0 / no to disable.
ENABLE_SOLANA=true

# ─── Payments ────────────────────────────────────────────────────────────────
# Razorpay (INR) — public key id in app; secret only in Supabase Edge Function
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Dodo / Stripe: prefer Supabase secrets on Edge Functions (create-dodo-checkout,
# create-stripe-checkout). Flags show the option in the app without putting secrets in .env (required for Flutter web).
CHECKOUT_ENABLE_DODO=false
CHECKOUT_ENABLE_STRIPE=false
# Dodo: required on the Edge Function for per-artwork checkout (not in Flutter .env):
#   supabase secrets set DODO_PAYMENTS_DEFAULT_PRODUCT_ID=pdt_...
# Use a one-time "pay what you want" product so checkout can charge each artwork's INR price (amount in paise).
#   supabase secrets set DODO_PAYMENTS_API_KEY=...
#   supabase secrets set DODO_PAYMENTS_MODE=test_mode
# Arc Pay: reserved; when supported, set true. UI still shows “Not enabled yet” until wired up.
CHECKOUT_ENABLE_ARC_PAY=false

# Optional: publishable key for future Stripe.js / Elements (Checkout uses Edge Function secret only).
STRIPE_PUBLISHABLE_KEY=
# Optional: only for native/dev — do not ship web with Dodo secret in .env
DODO_PAYMENTS_API_KEY=

# Return URL base if Uri.base.origin is wrong behind a proxy (e.g. https://app.artyug.art)
PUBLIC_SITE_URL=

API_BASE_URL=https://your-api.example.com

# ─── AI / Gemini ─────────────────────────────────────────────────────────────
# Get a key: https://aistudio.google.com/apikey  (also accepts GOOGLE_AI_API_KEY)
GEMINI_API_KEY=
# Optional. Default: gemini-2.5-flash (stable). Alternatives: gemini-2.5-flash-lite,
# gemini-2.5-pro, gemini-3-flash-preview — see https://ai.google.dev/gemini-api/docs/models/gemini
# GEMINI_MODEL=gemini-2.5-flash

# --- Stitch MCP (Remote MCP server) ------------------------------------------
# API key mode (recommended for local development):
STITCH_API_KEY=
# OAuth mode (short-lived token mode):
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# STITCH_ACCESS_TOKEN=

# ─── Notes ───────────────────────────────────────────────────────────────────
# 1. After editing .env, restart the Flutter app (hot restart, not hot reload).
# 2. Web builds embed .env at compile time — rebuild web after changes.
# 3. For Android APK: keys are read at runtime from the bundled .env asset.
